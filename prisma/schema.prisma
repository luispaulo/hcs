generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  brandName String
  message   String   @db.Text
  createdAt DateTime @default(now())
  status    String   @default("pending")

  @@index([email])
  @@index([createdAt])
}
